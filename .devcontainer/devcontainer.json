{
  "name": "User Access Control Lab",
  
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.wordWrap": "on"
      },
      "extensions": [
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },

  "postCreateCommand": "bash scripts/setup.sh && chmod +x scripts/*.sh",

  "remoteUser": "vscode"
}
